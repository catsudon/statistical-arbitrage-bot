# Copy to .env and fill in. `.env` is gitignored — never commit real keys.

# ── Exchange credentials ─────────────────────────────────────────────────────
# Required for live trading; data fetch works without keys (public endpoints).
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Set to 1 to use Binance testnet (paper trading on real infra, fake money)
BINANCE_TESTNET=0

# Binance US  (use --exchange binanceus)
BINANCEUS_API_KEY=
BINANCEUS_API_SECRET=
BINANCEUS_TESTNET=0

# ── Telegram alerts ──────────────────────────────────────────────────────────
# Optional. If unset, all alerts go to the console log instead.
# 1. Message @BotFather on Telegram → /newbot → copy token below
# 2. Message @userinfobot → copy your numeric chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Log verbosity ────────────────────────────────────────────────────────────
STATARB_LOG_LEVEL=INFO
